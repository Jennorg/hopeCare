<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="20" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.esperanza.hopecare.modules.dashboard.ui.DashboardController">
    <padding>
        <Insets top="24" right="24" bottom="24" left="24" />
    </padding>

    <!-- Fila 1: KPIs principales -->
    <HBox spacing="20">
        <VBox styleClass="card" HBox.hgrow="ALWAYS" prefHeight="110">
            <Label text="CITAS HOY" styleClass="section-title"/>
            <Label fx:id="lblCitasHoy" style="-fx-font-size: 36px; -fx-font-weight: 700; -fx-text-fill: #0d9488;"/>
        </VBox>
        <VBox styleClass="card" HBox.hgrow="ALWAYS" prefHeight="110">
            <Label text="ATENDIDOS HOY" styleClass="section-title"/>
            <Label fx:id="lblAtendidosHoy" style="-fx-font-size: 36px; -fx-font-weight: 700; -fx-text-fill: #0d9488;"/>
        </VBox>
        <VBox styleClass="card" HBox.hgrow="ALWAYS" prefHeight="110">
            <Label text="INGRESOS DEL MES" styleClass="section-title"/>
            <Label fx:id="lblIngresosMes" style="-fx-font-size: 36px; -fx-font-weight: 700; -fx-text-fill: #0d9488;"/>
        </VBox>
        <VBox styleClass="card" HBox.hgrow="ALWAYS" prefHeight="110">
            <Label text="ASISTENCIA" styleClass="section-title"/>
            <Label fx:id="lblAsistencia" style="-fx-font-size: 36px; -fx-font-weight: 700; -fx-text-fill: #0d9488;"/>
            <ProgressBar fx:id="barAsistencia" prefWidth="Infinity" progress="0" style="-fx-accent: #0d9488; -fx-pref-height: 8;"/>
        </VBox>
    </HBox>

    <!-- Fila 2: Estado de Citas + Alertas -->
    <HBox spacing="20">
        <VBox styleClass="card" HBox.hgrow="ALWAYS" prefHeight="160">
            <Label text="ESTADO DE CITAS DEL MES" styleClass="section-title"/>
            <HBox spacing="16" alignment="CENTER_LEFT" VBox.vgrow="ALWAYS">
                <VBox alignment="CENTER" prefWidth="100" prefHeight="80" style="-fx-background-color: #dbeafe; -fx-background-radius: 8; -fx-padding: 8;">
                    <Label text="PROGRAMADAS" style="-fx-font-size: 10px; -fx-font-weight: 700; -fx-text-fill: #1e40af; -fx-letter-spacing: 0.5px;"/>
                    <Label fx:id="lblProgramadas" style="-fx-font-size: 26px; -fx-font-weight: 700; -fx-text-fill: #1e40af;"/>
                </VBox>
                <VBox alignment="CENTER" prefWidth="100" prefHeight="80" style="-fx-background-color: #dcfce7; -fx-background-radius: 8; -fx-padding: 8;">
                    <Label text="ATENDIDAS" style="-fx-font-size: 10px; -fx-font-weight: 700; -fx-text-fill: #166534; -fx-letter-spacing: 0.5px;"/>
                    <Label fx:id="lblAtendidas" style="-fx-font-size: 26px; -fx-font-weight: 700; -fx-text-fill: #166534;"/>
                </VBox>
                <VBox alignment="CENTER" prefWidth="100" prefHeight="80" style="-fx-background-color: #fee2e2; -fx-background-radius: 8; -fx-padding: 8;">
                    <Label text="CANCELADAS" style="-fx-font-size: 10px; -fx-font-weight: 700; -fx-text-fill: #991b1b; -fx-letter-spacing: 0.5px;"/>
                    <Label fx:id="lblCanceladas" style="-fx-font-size: 26px; -fx-font-weight: 700; -fx-text-fill: #991b1b;"/>
                </VBox>
                <VBox alignment="CENTER" prefWidth="100" prefHeight="80" style="-fx-background-color: #fef3c7; -fx-background-radius: 8; -fx-padding: 8;">
                    <Label text="NO ASISTIO" style="-fx-font-size: 10px; -fx-font-weight: 700; -fx-text-fill: #92400e; -fx-letter-spacing: 0.5px;"/>
                    <Label fx:id="lblNoAsistio" style="-fx-font-size: 26px; -fx-font-weight: 700; -fx-text-fill: #92400e;"/>
                </VBox>
            </HBox>
        </VBox>
        <VBox styleClass="card" HBox.hgrow="ALWAYS" prefHeight="160">
            <Label text="ALERTAS Y PENDIENTES" styleClass="section-title"/>
            <VBox spacing="12" VBox.vgrow="ALWAYS" alignment="CENTER">
                <HBox spacing="8" alignment="CENTER_LEFT">
                    <Label text="&#x26A0;" style="-fx-font-size: 16px;"/>
                    <Label text="Med. Stock Bajo:" style="-fx-font-weight: 600; -fx-text-fill: #64748b;"/>
                    <Label fx:id="lblStockBajo" style="-fx-font-weight: 700; -fx-text-fill: #dc2626;"/>
                </HBox>
                <HBox spacing="8" alignment="CENTER_LEFT">
                    <Label text="&#x1F52C;" style="-fx-font-size: 16px;"/>
                    <Label text="Lab Pendientes:" style="-fx-font-weight: 600; -fx-text-fill: #64748b;"/>
                    <Label fx:id="lblLabPendientes" style="-fx-font-weight: 700; -fx-text-fill: #d97706;"/>
                </HBox>
                <HBox spacing="8" alignment="CENTER_LEFT">
                    <Label text="&#x1F4CB;" style="-fx-font-size: 16px;"/>
                    <Label text="Facturas Pend.:" style="-fx-font-weight: 600; -fx-text-fill: #64748b;"/>
                    <Label fx:id="lblFacturasPendientes" style="-fx-font-weight: 700; -fx-text-fill: #d97706;"/>
                </HBox>
            </VBox>
        </VBox>
    </HBox>

    <!-- Fila 3: Resumen Financiero + Registros Recientes -->
    <HBox spacing="20">
        <VBox styleClass="card" HBox.hgrow="ALWAYS" prefHeight="180">
            <Label text="RESUMEN FINANCIERO DEL MES" styleClass="section-title"/>
            <VBox spacing="12" VBox.vgrow="ALWAYS" alignment="CENTER">
                <HBox spacing="12" alignment="CENTER_LEFT" prefWidth="Infinity">
                    <Label text="Consultas:" prefWidth="100" style="-fx-font-weight: 600; -fx-text-fill: #64748b;"/>
                    <Label fx:id="lblIngConsultas" style="-fx-font-size: 18px; -fx-font-weight: 700; -fx-text-fill: #0d9488;"/>
                </HBox>
                <HBox spacing="12" alignment="CENTER_LEFT" prefWidth="Infinity">
                    <Label text="Farmacia:" prefWidth="100" style="-fx-font-weight: 600; -fx-text-fill: #64748b;"/>
                    <Label fx:id="lblIngFarmacia" style="-fx-font-size: 18px; -fx-font-weight: 700; -fx-text-fill: #0d9488;"/>
                </HBox>
                <HBox spacing="12" alignment="CENTER_LEFT" prefWidth="Infinity">
                    <Label text="Laboratorio:" prefWidth="100" style="-fx-font-weight: 600; -fx-text-fill: #64748b;"/>
                    <Label fx:id="lblIngLaboratorio" style="-fx-font-size: 18px; -fx-font-weight: 700; -fx-text-fill: #0d9488;"/>
                </HBox>
            </VBox>
        </VBox>
        <VBox styleClass="card" HBox.hgrow="ALWAYS" prefHeight="180">
            <Label text="REGISTROS RECIENTES" styleClass="section-title"/>
            <ListView fx:id="listRegistros" prefHeight="130" style="-fx-background-color: transparent;"/>
        </VBox>
    </HBox>

    <!-- Fila 4: Totales del Sistema -->
    <HBox styleClass="card" spacing="24" alignment="CENTER" prefHeight="70">
        <HBox spacing="6" alignment="CENTER">
            <Label text="Pacientes:" style="-fx-font-weight: 600; -fx-text-fill: #64748b; -fx-font-size: 14px;"/>
            <Label fx:id="lblTotalPacientes" style="-fx-font-size: 18px; -fx-font-weight: 700; -fx-text-fill: #0f172a;"/>
        </HBox>
        <Label text="|" style="-fx-text-fill: #e2e8f0; -fx-font-size: 20px;"/>
        <HBox spacing="6" alignment="CENTER">
            <Label text="Medicos:" style="-fx-font-weight: 600; -fx-text-fill: #64748b; -fx-font-size: 14px;"/>
            <Label fx:id="lblTotalMedicos" style="-fx-font-size: 18px; -fx-font-weight: 700; -fx-text-fill: #0f172a;"/>
        </HBox>
        <Label text="|" style="-fx-text-fill: #e2e8f0; -fx-font-size: 20px;"/>
        <HBox spacing="6" alignment="CENTER">
            <Label text="Medicamentos:" style="-fx-font-weight: 600; -fx-text-fill: #64748b; -fx-font-size: 14px;"/>
            <Label fx:id="lblTotalMedicamentos" style="-fx-font-size: 18px; -fx-font-weight: 700; -fx-text-fill: #0f172a;"/>
        </HBox>
        <Label text="|" style="-fx-text-fill: #e2e8f0; -fx-font-size: 20px;"/>
        <HBox spacing="6" alignment="CENTER">
            <Label text="Examenes:" style="-fx-font-weight: 600; -fx-text-fill: #64748b; -fx-font-size: 14px;"/>
            <Label fx:id="lblTotalExamenes" style="-fx-font-size: 18px; -fx-font-weight: 700; -fx-text-fill: #0f172a;"/>
        </HBox>
    </HBox>
</VBox>
