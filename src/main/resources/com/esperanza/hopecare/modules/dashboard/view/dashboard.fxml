<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="20" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.esperanza.hopecare.modules.dashboard.ui.DashboardController">
    <padding>
        <Insets top="24" right="24" bottom="24" left="24" />
    </padding>

    <HBox spacing="20" alignment="CENTER">
        <VBox styleClass="card" HBox.hgrow="ALWAYS" prefHeight="100">
            <Label text="CITAS DE HOY" styleClass="section-title"/>
            <Label fx:id="lblCitasHoy" styleClass="label-header" style="-fx-font-size: 32px; -fx-text-fill: #0d9488;"/>
        </VBox>
        <VBox styleClass="card" HBox.hgrow="ALWAYS" prefHeight="100">
            <Label text="INGRESOS DEL MES" styleClass="section-title"/>
            <Label fx:id="lblIngresosMes" styleClass="label-header" style="-fx-font-size: 32px; -fx-text-fill: #0d9488;"/>
        </VBox>
    </HBox>

    <VBox styleClass="card">
        <Label text="MEDICAMENTOS CON STOCK BAJO" styleClass="section-title"/>
        <ListView fx:id="listStockBajo" prefHeight="200" style="-fx-background-color: transparent;"/>
    </VBox>
</VBox>
