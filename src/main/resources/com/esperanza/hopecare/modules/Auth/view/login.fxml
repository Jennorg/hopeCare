<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.shape.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.esperanza.hopecare.modules.Auth.view.LoginController"
            styleClass="auth-root"
            stylesheets="@../../../main/hopecare.css">

    <top>
        <VBox styleClass="auth-header" alignment="CENTER">
            <padding><Insets top="28" bottom="28" left="40" right="40"/></padding>

            <Label text="HopeCare" styleClass="auth-logo"/>
            <Label text="Sistema de Gestión Hospitalaria" styleClass="auth-logo-sub"/>
        </VBox>
    </top>

    <center>
        <StackPane styleClass="auth-center-bg">

            <VBox styleClass="auth-card" alignment="TOP_LEFT" maxWidth="400" maxHeight="380">
                <padding><Insets top="32" bottom="32" left="36" right="36"/></padding>
                <spacing>0</spacing>

                <Label text="Iniciar Sesión" styleClass="card-title"/>
                <Separator styleClass="card-sep"/>
                <Region minHeight="18"/>

                <VBox fx:id="formContainer" spacing="0">
                    <Label text="Usuario" styleClass="field-label"/>
                    <Region minHeight="4"/>
                    <TextField fx:id="txtUsuario"
                               promptText="Ingresa tu nombre de usuario"
                               styleClass="auth-field"/>
                    <Region minHeight="14"/>

                    <Label text="Contraseña" styleClass="field-label"/>
                    <Region minHeight="4"/>
                    <PasswordField fx:id="txtContrasena"
                                   promptText="Ingresa tu contraseña"
                                   styleClass="auth-field"/>
                    <Region minHeight="8"/>

                    <Label fx:id="lblMensaje" text=" " styleClass="msg-error" wrapText="true"/>
                    <Region minHeight="12"/>

                    <Button fx:id="btnIngresar"
                            text="Ingresar al Sistema"
                            styleClass="btn-primary"
                            maxWidth="Infinity"
                            onAction="#handleLogin"/>
                    <Region minHeight="10"/>

                    <HBox alignment="CENTER">
                        <Label text="¿No tienes cuenta? " styleClass="link-text-muted"/>
                        <Hyperlink fx:id="linkRegistro"
                                   text="Regístrate aquí"
                                   styleClass="link-accent"
                                   onAction="#goToSignup"/>
                    </HBox>
                </VBox>

                <VBox fx:id="loadingContainer" spacing="14" alignment="CENTER" managed="false" visible="false">
                    <Region minHeight="10"/>
                    <Label text="Iniciando sesión..." style="-fx-font-weight: bold; -fx-font-size: 15px; -fx-text-fill: #0f766e;"/>
                    <Label text="Cargando tu espacio de trabajo..." style="-fx-text-fill: #64748b; -fx-font-size: 12px;"/>
                    <ProgressBar fx:id="progressCarga" progress="0.0" maxWidth="Infinity" styleClass="loading-bar"/>
                    <Region minHeight="10"/>
                </VBox>

            </VBox>
        </StackPane>
    </center>

    <bottom>
        <Label text="© 2025 HopeCare – Sisgeho v1.0"
               styleClass="auth-footer"
               maxWidth="Infinity"
               alignment="CENTER">
            <BorderPane.margin><Insets bottom="12"/></BorderPane.margin>
        </Label>
    </bottom>

</BorderPane>
