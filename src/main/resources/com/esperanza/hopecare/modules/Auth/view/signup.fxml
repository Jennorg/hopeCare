<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.esperanza.hopecare.modules.Auth.view.SignupController"
            styleClass="auth-root"
            stylesheets="@../../../main/hopecare.css">

    <top>
        <BorderPane styleClass="auth-header">
            <padding><Insets top="18" bottom="18" left="30" right="30"/></padding>

            <left>
                <Hyperlink text="← Volver al Login"
                           styleClass="header-back-link"
                           onAction="#goToLogin"/>
            </left>

            <center>
                <HBox alignment="CENTER" spacing="10">
                    <!-- Vector SVG Logo -->
                    <Pane prefWidth="48" prefHeight="48" minWidth="48" minHeight="48" maxWidth="48" maxHeight="48">
                        <Group scaleX="0.0476" scaleY="0.0476" translateX="-480" translateY="-497.5">
