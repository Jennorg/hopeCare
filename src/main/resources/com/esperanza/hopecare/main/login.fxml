<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.shape.SVGPath?>
<?import javafx.scene.layout.Pane?>

<StackPane xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.esperanza.hopecare.main.LoginController" style="-fx-background-color: #f5f7fa;">
    <VBox alignment="CENTER" spacing="30" maxWidth="400">
        <padding>
            <Insets top="50" right="50" bottom="50" left="50"/>
        </padding>
        <VBox alignment="CENTER" spacing="10">
             <HBox spacing="10" alignment="CENTER">
                 <Pane prefWidth="48" prefHeight="48" style="-fx-background-color: #0d9488; -fx-background-radius: 10;">
                     <SVGPath content="M 12 12 c 2.21 0 4 -1.79 4 -4 s -1.79 -4 -4 -4 s -4 1.79 -4 4 s 1.79 4 4 4 z m 0 2 c -2.67 0 -8 1.34 -8 4 v 2 h 16 v -2 c 0 -2.66 -5.33 -4 -8 -4 z" fill="white" layoutX="12" layoutY="12" scaleX="1.5" scaleY="1.5"/>
                 </Pane>
                 <Label text="HopeCare" style="-fx-font-size: 32; -fx-font-weight: bold; -fx-text-fill: #2d3748;"/>
             </HBox>
             <Label text="Módulo Pacientes y Médicos" style="-fx-font-size: 14; -fx-text-fill: #718096;"/>
        </VBox>

        <VBox spacing="20" style="-fx-background-color: white; -fx-padding: 40; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);">
            <VBox spacing="8">
                <Label text="Usuario" style="-fx-font-weight: bold; -fx-text-fill: #4a5568;"/>
                <TextField fx:id="txtUsuario" promptText="Ingrese su usuario" style="-fx-padding: 10; -fx-background-radius: 5;"/>
            </VBox>
            <VBox spacing="8">
                <Label text="Contraseña" style="-fx-font-weight: bold; -fx-text-fill: #4a5568;"/>
                <PasswordField fx:id="txtPassword" promptText="Ingrese su contraseña" style="-fx-padding: 10; -fx-background-radius: 5;"/>
            </VBox>
            <Button text="Iniciar Sesión" onAction="#handleLogin" maxWidth="Infinity" style="-fx-background-color: #0d9488; -fx-text-fill: white; -fx-padding: 12; -fx-font-weight: bold; -fx-background-radius: 5; -fx-cursor: hand;"/>
        </VBox>
        
        <Label text="© 2026 HopeCare - Todos los derechos reservados" style="-fx-font-size: 12; -fx-text-fill: #a0aec0;"/>
    </VBox>
</StackPane>
