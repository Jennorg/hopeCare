<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.shape.SVGPath?>
<?import javafx.scene.Group?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.esperanza.hopecare.main.MainController" styleClass="main-container">
    <top>
        <VBox styleClass="header-container">
            <HBox fx:id="headerTop" styleClass="header-top" alignment="CENTER_LEFT" spacing="0">
                <HBox fx:id="logoSection" styleClass="logo-section" spacing="10" alignment="CENTER_LEFT">
                    <Label text="🏥" style="-fx-font-size: 28px;"/>
                    <Label text="HopeCare" styleClass="logo-text"/>
                </HBox>

                <!-- Responsive Spacers -->
                <Pane fx:id="spacer1" HBox.hgrow="ALWAYS" />

                <FlowPane fx:id="navLinks" styleClass="nav-links" alignment="CENTER" columnHalignment="CENTER" hgap="20" vgap="8">
                    <Hyperlink fx:id="linkDashboard" text="Dashboard" styleClass="nav-link" onAction="#navigateToDashboard"/>
                </FlowPane>

                <Pane fx:id="spacer2" HBox.hgrow="ALWAYS" />

                <HBox fx:id="userSection" styleClass="user-section" spacing="12" alignment="CENTER_RIGHT">
                    <HBox styleClass="user-info" spacing="10" alignment="CENTER" onMouseClicked="#onUserProfileClick">
                        <VBox alignment="CENTER_RIGHT">
                            <Label fx:id="lblUserName" text="Admin Principal" styleClass="user-name"/>
                            <Label fx:id="lblUserRole" text="SISTEMAS" styleClass="user-role"/>
                        </VBox>
                        <StackPane prefWidth="32" prefHeight="32" alignment="CENTER">
                            <SVGPath content="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z" scaleX="1.3" scaleY="1.3" styleClass="user-icon-svg"/>
                        </StackPane>
                    </HBox>
                </HBox>
            </HBox>

            <!-- Compact mode stacked row for Navigation Links -->
            <FlowPane fx:id="headerMiddle" styleClass="header-middle" alignment="CENTER" columnHalignment="CENTER" managed="false" visible="false">
                <!-- Links will move here dynamically -->
            </FlowPane>
            <HBox styleClass="header-bottom">
                <Label fx:id="lblBreadcrumb" text="Inicio > Dashboard" styleClass="breadcrumb"/>
            </HBox>
        </VBox>
    </top>
    <center>
        <TabPane fx:id="mainTabPane" tabClosingPolicy="UNAVAILABLE" styleClass="main-tabs">
            <Tab fx:id="tabDashboard" text="" closable="false">
                <fx:include source="../modules/dashboard/view/dashboard.fxml"/>
            </Tab>
        </TabPane>
    </center>
</BorderPane>