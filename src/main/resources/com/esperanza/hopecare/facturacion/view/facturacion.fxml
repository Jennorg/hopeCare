<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="15" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.esperanza.hopecare.facturacion.view.FacturacionController">
    <padding>
        <Insets top="20" right="20" bottom="20" left="20" />
    </padding>

    <TabPane prefHeight="280">
        <Tab text="Citas" closable="false">
            <VBox spacing="10">
                <padding><Insets top="10" right="10" bottom="10" left="10" /></padding>
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="Buscar paciente:" />
                    <TextField fx:id="txtBuscarCita" prefWidth="250" promptText="Filtrar por nombre..." />
                    <Button fx:id="btnGenCita" text="Generar Factura" />
                </HBox>
                <TableView fx:id="tablaCitasPendientes" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colCitaIdRef" text="ID Consulta" prefWidth="100" />
                        <TableColumn fx:id="colCitaPaciente" text="Paciente" prefWidth="180" />
                        <TableColumn fx:id="colCitaConcepto" text="Concepto" prefWidth="200" />
                        <TableColumn fx:id="colCitaMonto" text="Monto" prefWidth="120" />
                        <TableColumn fx:id="colCitaFecha" text="Fecha" prefWidth="150" />
                    </columns>
                </TableView>
            </VBox>
        </Tab>
        <Tab text="Farmacia" closable="false">
            <VBox spacing="10">
                <padding><Insets top="10" right="10" bottom="10" left="10" /></padding>
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="Buscar paciente:" />
                    <TextField fx:id="txtBuscarFarm" prefWidth="250" promptText="Filtrar por nombre..." />
                    <Button fx:id="btnGenFarm" text="Generar Factura" />
                </HBox>
                <TableView fx:id="tablaFarmPendientes" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colFarmIdRef" text="ID Entrega" prefWidth="100" />
                        <TableColumn fx:id="colFarmPaciente" text="Paciente" prefWidth="180" />
                        <TableColumn fx:id="colFarmConcepto" text="Medicamento" prefWidth="200" />
                        <TableColumn fx:id="colFarmMonto" text="Monto" prefWidth="120" />
                        <TableColumn fx:id="colFarmFecha" text="Fecha" prefWidth="150" />
                    </columns>
                </TableView>
            </VBox>
        </Tab>
        <Tab text="Laboratorio" closable="false">
            <VBox spacing="10">
                <padding><Insets top="10" right="10" bottom="10" left="10" /></padding>
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="Buscar paciente:" />
                    <TextField fx:id="txtBuscarLab" prefWidth="250" promptText="Filtrar por nombre..." />
                    <Button fx:id="btnGenLab" text="Generar Factura" />
                </HBox>
                <TableView fx:id="tablaLabPendientes" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colLabIdRef" text="ID Solicitud" prefWidth="100" />
                        <TableColumn fx:id="colLabPaciente" text="Paciente" prefWidth="180" />
                        <TableColumn fx:id="colLabConcepto" text="Examen" prefWidth="200" />
                        <TableColumn fx:id="colLabMonto" text="Monto" prefWidth="120" />
                        <TableColumn fx:id="colLabFecha" text="Fecha" prefWidth="150" />
                    </columns>
                </TableView>
            </VBox>
        </Tab>
    </TabPane>

    <Label text="Facturas emitidas:" style="-fx-font-weight: bold;" />
    <TableView fx:id="tablaFacturas" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colId" text="ID" prefWidth="60" />
            <TableColumn fx:id="colPaciente" text="Paciente" prefWidth="200" />
            <TableColumn fx:id="colFecha" text="Fecha" prefWidth="160" />
            <TableColumn fx:id="colSubtotal" text="Subtotal" prefWidth="100" />
            <TableColumn fx:id="colImpuesto" text="Impuesto" prefWidth="100" />
            <TableColumn fx:id="colTotal" text="Total" prefWidth="100" />
            <TableColumn fx:id="colEstado" text="Estado" prefWidth="100" />
        </columns>
    </TableView>
</VBox>
